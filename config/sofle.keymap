#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/gpio/gpio.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,display = &oled;
    };

    // ===== 适配128x16超窄长条屏（长宽比8:1，>5倍）=====
    oled: oled {
        compatible = "zmk,oled-display";
        // ZMK v0.2 专用：禁用复杂状态栏，只保留极简文本显示（和你原图一致）
        simple-display {
            compatible = "zmk,simple-display";
            // 显示内容：层（Base）+ 蓝牙配置（XCM）+ 电池，和你原图完全匹配
            format = "L:%l BT:%b BAT:%p%%";
            // 128x16超窄屏专属：字体缩小+显示区域居中
            font = "zmk,font-mono-4x6"; // 适配超窄屏的最小字体
            offset-x = <0>;
            offset-y = <0>;
        };
        // 超窄屏必须的I2C配置（供电+通信）
        i2c {
            compatible = "i2c-device";
            i2c-bus = <&i2c0>;
            i2c-address = <0x3C>; // 多数128x16屏默认地址，不行改0x3D
        };
        // 横屏显示（和你原图一致，不旋转）
        rotation = <0>;
    };

    // ===== Sofle v2 I2C总线（给128x16屏供电）=====
    &i2c0 {
        status = "okay";
        sda-pin = <&gpio0 06 GPIO_ACTIVE_HIGH>;
        scl-pin = <&gpio0 07 GPIO_ACTIVE_HIGH>;
        clock-frequency = <100000>; // 128x16屏用低速I2C更稳定
    };

    // ===== 基础键位（不变）=====
    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &esc  &1    &2    &3    &4    &5                   &6    &7    &8    &9    &0    &minus
                &tab  &q    &w    &e    &r    &t                   &y    &u    &i    &o    &p    &equals
                &caps &a    &s    &d    &f    &g                   &h    &j    &k    &l    &scln &quote
                &lsft &z    &x    &c    &v    &b                   &n    &m    &comma &dot  &slash &rsft
                &lctrl &lgui &alt  &backspace &space  &enter       &left &down &up   &right &del  &rctrl
            >;
        };
    };

    // ===== 键盘扫描配置（不变）=====
    &kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        row-gpios = <&gpio0 29 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 28 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 27 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 26 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 22 GPIO_ACTIVE_LOW GPIO_PULL_UP>;
        col-gpios = <&gpio0 20 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 21 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 23 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 24 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio0 25 GPIO_ACTIVE_LOW GPIO_PULL_UP>,
                    <&gpio1 06 GPIO_ACTIVE_LOW GPIO_PULL_UP>;
    };
};